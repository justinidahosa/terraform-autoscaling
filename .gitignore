# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude variable definitions with secrets (optional)
terraform.tfvars
*.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Local environment files
*.env
*.bak

# CLI configuration
.terraformrc
terraform.rc
